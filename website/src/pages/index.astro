---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/home/Hero.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import VideoDemo from "@/components/ui/VideoDemo.tsx";
import { stages } from "@/lib/pipeline";

const features = [
  {
    title: "A deterministic pipeline",
    body: "Discovery, dedupe, constraints, thresholding, and the daily report are plain Python. Zero tokens spent before a job earns them.",
  },
  {
    title: "AI only where it reasons",
    body: "Two model calls that need judgment: a cheap keep/drop gate, and one real evaluation per job that survives it. Nothing else.",
  },
  {
    title: "Two sources of truth",
    body: "Your profile facts and each job's evaluation are written once. Every resume, cover letter, and report is a derivation, never a re-derivation.",
  },
  {
    title: "Everything is cached",
    body: "Each AI output is fingerprinted by job, profile version, and prompt version. Re-run a day with nothing changed and it costs zero calls.",
  },
  {
    title: "CLI-agnostic by construction",
    body: "The host coding agent is both runtime and model. Runs under Claude Code, Codex, Gemini CLI, or OpenCode without changing a line.",
  },
  {
    title: "No server, no database",
    body: "The filesystem is the message bus. Every stage reads one JSON file and writes another, so every run is inspectable and resumable.",
  },
];

const previewStages = stages.filter((s) =>
  ["discover", "constraints", "gate", "evaluate", "threshold", "apply"].includes(s.id)
);
---
<BaseLayout>
  <Hero />

  <!-- Why it exists -->
  <section class="border-b border-border py-20">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
        <div data-reveal>
          <p class="eyebrow mb-3">Why CareerOS exists</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            Most AI job tools fail in one of two ways.
          </h2>
        </div>
        <div class="flex flex-col gap-6" data-reveal data-reveal-delay="80ms">
          <p class="text-[15px] leading-relaxed text-ink-2">
            They spam applications with generic resumes. Or they burn expensive
            AI calls evaluating and writing long reports for every job they find
            — most of which you will never apply to.
          </p>
          <p class="text-[15px] leading-relaxed text-ink-2">
            CareerOS is built around one rule:
            <strong class="text-ink">
              use deterministic code wherever possible, and AI only where
              reasoning genuinely adds value.
            </strong>
            The KPI is simple — more interviews, for the least amount of AI and
            compute cost. A day with zero interview-worthy jobs is a legitimate
            outcome, never a reason to lower the bar.
          </p>
          <div>
            <Button href="/philosophy/" variant="ghost" class="-ml-4">
              Read the philosophy
              <span aria-hidden="true">→</span>
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture preview -->
  <section class="border-b border-border py-20">
    <div class="container-page">
      <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end" data-reveal>
        <div class="max-w-xl">
          <p class="eyebrow mb-3">The pipeline</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            Cheap, deterministic filtering first. Expensive reasoning last.
          </h2>
          <p class="mt-4 text-[15px] leading-relaxed text-muted">
            Each stage reads one file and writes the next. A job is only shown a
            model once it has survived every step that costs nothing.
          </p>
        </div>
        <Button href="/architecture/" variant="secondary">Explore each stage</Button>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-delay="60ms">
        {
          previewStages.map((s, i) => (
            <div class="rounded-xl border border-border bg-surface p-5">
              <div class="mb-3 flex items-center justify-between">
                <span class="font-mono text-xs text-faint">
                  {String(i + 1).padStart(2, "0")}
                </span>
                {s.kind === "reasoning" ? (
                  <Badge variant="reasoning">AI reasoning</Badge>
                ) : s.kind === "output" ? (
                  <Badge variant="output">Output</Badge>
                ) : (
                  <Badge variant="deterministic">Deterministic</Badge>
                )}
              </div>
              <p class="text-[15px] font-medium text-ink">{s.name}</p>
              <p class="mt-1.5 text-sm leading-relaxed text-muted">{s.purpose}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Two sources of truth -->
  <section class="border-b border-border py-20">
    <div class="container-page">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div data-reveal>
          <p class="eyebrow mb-3">Selector, not writer</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            Two files. Everything else is a derivation.
          </h2>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-2">
            Everything CareerOS generates traces back to exactly two files: your
            <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-[13px]">profile.yaml</code>
            — your facts, written once — and each job's evaluation JSON, its fit
            judgment, written once by the evaluate stage.
          </p>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-2">
            A resume never invents a bullet. A cover letter never claims
            something not in your profile.
          </p>
          <div class="mt-6 rounded-xl border border-border bg-surface p-5">
            <div class="mb-2 flex items-center gap-2">
              <span class="font-mono text-xs text-accent">profile.yaml</span>
              <Badge variant="accent">Source of truth</Badge>
            </div>
            <p class="text-sm leading-relaxed text-muted">
              Your verbatim experience, targets, and constraints. Generated once
              via <code class="font-mono text-[13px]">careeros start</code>, edited rarely.
            </p>
          </div>
        </div>
        <div class="flex flex-col gap-3" data-reveal data-reveal-delay="80ms">
          <div class="flex items-center gap-2 text-faint">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
            <span class="text-xs">derives, never re-derives</span>
          </div>
          <VideoDemo
            client:visible
            src="resume-cover"
            label="resume.md + cover.md, written live"
            caption="A deterministic check refuses to cache a resume whose lines don't verbatim-match your profile — this is that write, unedited. The daily report and application answers derive the same way."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Watch it actually run -->
  <section class="border-b border-border py-20">
    <div class="container-page">
      <div class="mb-10 max-w-2xl" data-reveal>
        <p class="eyebrow mb-3">Not a mockup</p>
        <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
          Watch it actually run.
        </h2>
        <p class="mt-4 text-[15px] leading-relaxed text-muted">
          Real terminal output from a real <code class="rounded bg-surface-2 px-1.5 py-0.5 font-mono text-[13px]">careeros daily</code> run — unedited, including where the pipeline pushes back.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2" data-reveal data-reveal-delay="60ms">
        <VideoDemo
          client:visible
          src="gate-parallel"
          label="gate stage — 7 parallel agents"
          caption="Seven background agents dispatched at once, each reasoning through its own batch of jobs — with live token and time counters, not a progress bar."
        />
        <VideoDemo
          client:visible
          src="apply-honest"
          label="apply stage — a dead listing"
          caption="Egnyte's posting had expired. Per the apply prompt's rule, CareerOS won't invent answers for a listing that no longer exists — it flags it and moves on."
        />
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="py-20">
    <div class="container-page">
      <div class="mb-12 max-w-2xl" data-reveal>
        <p class="eyebrow mb-3">What makes it different</p>
        <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
          Architecture decisions you can read end to end.
        </h2>
      </div>
      <div class="grid gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3" data-reveal>
        {
          features.map((f) => (
            <div class="flex flex-col bg-surface p-6">
              <h3 class="text-[15px] font-semibold text-ink">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{f.body}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8" data-reveal>
        <Button href="/product-decisions/" variant="ghost" class="-ml-4">
          Read the reasoning behind each decision
          <span aria-hidden="true">→</span>
        </Button>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="border-t border-border">
    <div class="container-page py-20">
      <div class="relative overflow-hidden rounded-2xl border border-border bg-surface px-8 py-14 text-center">
        <div class="pointer-events-none absolute inset-0 grid-backdrop opacity-60"></div>
        <div class="relative mx-auto max-w-xl">
          <h2 class="text-balance text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            Open source, MIT-licensed, and honest about what it does.
          </h2>
          <p class="mx-auto mt-4 max-w-md text-[15px] leading-relaxed text-muted">
            Read the code, run it locally, and see every decision for yourself.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <Button href="https://github.com/vbkatarnaware/careeros" external size="lg">
              View on GitHub
            </Button>
            <Button href="/docs/" variant="secondary" size="lg">Read the docs</Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
