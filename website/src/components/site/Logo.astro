---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<a href="/" class={`group inline-flex items-center gap-2.5 ${className}`} aria-label="CareerOS home">
  <span class="relative inline-flex h-7 w-7 items-center justify-center">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
      <rect x="0.5" y="0.5" width="27" height="27" rx="7.5" fill="var(--surface)" stroke="var(--border-strong)"></rect>
      <g transform="translate(5,5) scale(0.75)">
        <path d="M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 01.75.75c0 5.056-2.383 9.555-6.084 12.436A6.75 6.75 0 019.75 22.5a.75.75 0 01-.75-.75v-4.131A15.838 15.838 0 016.382 15H2.25a.75.75 0 01-.75-.75 6.75 6.75 0 017.815-6.666z" fill="var(--ink)"></path>
        <path d="M5.26 17.242a.75.75 0 10-.897-1.203 5.243 5.243 0 00-2.05 5.022.75.75 0 00.625.627 5.243 5.243 0 005.022-2.051.75.75 0 10-1.202-.897 3.744 3.744 0 01-3.008 1.51c0-1.23.592-2.323 1.51-3.008z" fill="var(--muted)"></path>
        <circle cx="15" cy="9" r="2.25" fill="var(--accent)"></circle>
      </g>
    </svg>
  </span>
  <span class="text-[15px] font-semibold tracking-tight text-ink">CareerOS</span>
</a>
